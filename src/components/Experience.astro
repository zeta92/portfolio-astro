---
import type { Translations } from '../i18n/en';
import { press } from '../data/press';

interface Props { t: Translations; }
const { t } = Astro.props;
const exp = t.experience;

const companyKeys = [
  'happening',
  'chiliz',
  'bridder',
  'waveApplication',
  'solera',
  'streye',
  'everis',
  'navionTruck',
  'coordaNetworks',
];
---
<section class="experience" id="experience">
  <div class="experience__inner">
    <div class="experience__header">
      <h2 class="experience__heading reveal">{exp.heading}</h2>
      <span class="experience__count reveal">{exp.count}</span>
    </div>
    <div class="timeline">
      {exp.jobs.map((job, i) => {
        const articles = press[companyKeys[i]] ?? [];
        return (
          <div class="timeline-item">
            <div class="timeline-item__years">
              <strong>{job.period}</strong>
              {job.company}
            </div>
            <div class="timeline-item__content">
              <h3 class="timeline-item__role">{job.role}</h3>
              <p class="timeline-item__company">{job.subtitle}</p>
              <p class="timeline-item__desc" set:html={job.desc} />
              <div class="timeline-item__tags">
                {job.tags.map((tag, idx) => (
                  <span class={`tag--dark${job.accent.includes(idx) ? ' tag--dark-accent' : ''}`}>{tag}</span>
                ))}
              </div>
              {articles.length > 0 && (
                <div class="press-row">
                  <span class="press-row__label">{exp.pressLabel}</span>
                  {articles.map(article => (
                    <a
                      class="press-badge"
                      href={article.url}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      <div class="press-badge__logo">{article.logoText}</div>
                      <div class="press-badge__body">
                        <span class="press-badge__source">{article.source}</span>
                        <span class="press-badge__headline">{article.headline}</span>
                      </div>
                      <span class="press-badge__arrow">↗</span>
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .experience { background: var(--near-black); padding: var(--space-10) var(--space-8); }
  .experience__inner { max-width: 1280px; margin: 0 auto; }
  .experience__header {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-bottom: var(--space-9); flex-wrap: wrap; gap: var(--space-4);
  }
  .experience__heading {
    font-family: var(--font-display); font-size: clamp(36px,5vw,64px);
    font-weight: 800; letter-spacing: -0.03em; line-height: 1; color: var(--ivory);
  }
  .experience__count {
    font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--text-tertiary); padding-bottom: 4px;
  }
  .timeline { display: flex; flex-direction: column; gap: 2px; }
  .timeline-item {
    display: grid; grid-template-columns: 140px 1fr; gap: var(--space-6);
    padding: var(--space-6) 0; border-top: 1px solid rgba(255,255,255,0.06);
    opacity: 0; transform: translateY(20px);
    transition: opacity 0.7s ease, transform 0.7s ease;
    cursor: pointer;
  }
  .timeline-item.visible { opacity: 1; transform: translateY(0); }
  .timeline-item:last-child { border-bottom: 1px solid rgba(255,255,255,0.06); }
  .timeline-item:hover .timeline-item__content { padding-left: var(--space-4); }
  .timeline-item__content { transition: padding-left 0.25s ease; }
  .timeline-item__years {
    font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.06em;
    color: var(--text-tertiary); padding-top: 3px; line-height: 1.5;
  }
  .timeline-item__years strong {
    display: block; font-family: var(--font-display); font-size: 13px; font-weight: 700;
    letter-spacing: 0.04em; color: var(--text-light); margin-bottom: 2px;
  }
  .timeline-item__role {
    font-family: var(--font-display); font-size: clamp(20px,2.5vw,28px);
    font-weight: 700; letter-spacing: -0.02em; line-height: 1.15; color: var(--ivory); margin-bottom: 4px;
  }
  .timeline-item__company {
    font-family: var(--font-serif); font-size: 16px; font-style: italic;
    color: var(--terracotta); margin-bottom: var(--space-3);
  }
  .timeline-item__desc {
    font-family: var(--font-serif); font-size: 16px; line-height: 1.65;
    color: var(--text-light); max-width: 64ch; margin-bottom: var(--space-4);
  }
  .timeline-item__tags { display: flex; flex-wrap: wrap; gap: 6px; }
  @media (max-width: 900px) {
    .experience { padding: var(--space-8) var(--space-5); }
    .experience__header { margin-bottom: var(--space-7); }
    .timeline-item { grid-template-columns: 1fr; gap: var(--space-3); }
    .timeline-item__years { display: flex; align-items: center; gap: var(--space-3); }
  }

  /* ── Press badges ───────────────────────────── */
  .press-row {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding-top: var(--space-3);
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .press-row__label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(176,174,165,0.4);
  }
  .press-badge {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    border-radius: 6px;
    background: rgba(255,255,255,0.03);
    box-shadow: 0px 0px 0px 1px rgba(255,255,255,0.06);
    text-decoration: none;
    max-width: min(520px, 100%);
    min-width: 0;
    transition: background var(--ease-color), box-shadow var(--ease-shadow);
  }
  .press-badge:hover {
    background: rgba(255,255,255,0.06);
    box-shadow: 0px 0px 0px 1px rgba(255,255,255,0.10);
  }
  .press-badge__logo {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 4px;
    background: rgba(255,255,255,0.07);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--text-light);
  }
  .press-badge__body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .press-badge__source {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.05em;
    color: var(--terracotta);
  }
  .press-badge__headline {
    font-family: var(--font-serif);
    font-size: 13px;
    color: rgba(176,174,165,0.85);
    line-height: 1.35;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .press-badge__arrow {
    flex-shrink: 0;
    font-size: 12px;
    color: rgba(176,174,165,0.25);
    transition: color var(--ease-color);
  }
  .press-badge:hover .press-badge__arrow {
    color: rgba(176,174,165,0.6);
  }
</style>
