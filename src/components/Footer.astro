---
import type { Translations } from '../i18n/en';
interface Props { t: Translations; }
const { t } = Astro.props;
const f = t.footer;
---
<footer class="footer">
  <span class="footer__copy">{f.copy}</span>
  <span class="footer__made">{f.made} <span>{f.stack}</span></span>
</footer>

<style>
  .footer {
    background: var(--bg-base);
    border-top: 1px solid var(--border-subtle);
    padding: var(--space-6) var(--space-8);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .footer__copy {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }
  .footer__made {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
  }
  .footer__made span { color: var(--accent-bright); }
  @media (max-width: 900px) { .footer { padding: var(--space-5); } }
</style>
