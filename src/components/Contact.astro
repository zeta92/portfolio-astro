---
import type { Translations } from '../i18n/en';
interface Props { t: Translations; }
const { t } = Astro.props;
const c = t.contact;
---
<section class="contact" id="contact">
  <div class="contact__inner">
    <div>
      <p class="section-label reveal" style="color: var(--terracotta);">{c.label}</p>
      <h2 class="contact__heading reveal">{c.heading1}<br /><em>{c.heading2}</em></h2>
      <p class="contact__text reveal">{c.body}</p>
    </div>
    <div class="contact__links reveal">
      <a href="mailto:luist.webdesigner@gmail.com" class="contact-link">
        <div>
          <div class="contact-link__label">{c.links.email}</div>
          <div class="contact-link__value">luist.webdesigner@gmail.com</div>
        </div>
        <span class="contact-link__arrow">→</span>
      </a>
      <a href="tel:+34640140813" class="contact-link">
        <div>
          <div class="contact-link__label">{c.links.phone}</div>
          <div class="contact-link__value">+34 640 140 813</div>
        </div>
        <span class="contact-link__arrow">→</span>
      </a>
      <a href="https://www.linkedin.com/in/luis-tiburcio-de-la-cruz/" class="contact-link" target="_blank" rel="noopener">
        <div>
          <div class="contact-link__label">{c.links.linkedin}</div>
          <div class="contact-link__value">linkedin.com/in/luis-tiburcio-de-la-cruz</div>
        </div>
        <span class="contact-link__arrow">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .contact { background: var(--near-black); padding: var(--space-10) var(--space-8); position: relative; overflow: hidden; }
  .contact__inner {
    max-width: 1280px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-9); align-items: center;
  }
  .contact__heading {
    font-family: var(--font-display); font-size: clamp(40px,6vw,80px);
    font-weight: 800; letter-spacing: -0.03em; line-height: 0.95;
    color: var(--ivory); margin-bottom: var(--space-5);
  }
  .contact__heading em { font-style: normal; color: var(--terracotta); }
  .contact__text { font-family: var(--font-serif); font-size: 19px; font-style: italic; line-height: 1.65; color: var(--text-light); }
  .contact__links { display: flex; flex-direction: column; gap: var(--space-4); }
  .contact-link {
    display: flex; align-items: center; justify-content: space-between;
    padding: var(--space-5) var(--space-6); border-radius: 12px;
    background: rgba(255,255,255,0.04); box-shadow: var(--shadow-card-dark);
    transition: background var(--ease-color), transform 0.2s ease;
  }
  .contact-link:hover { background: rgba(255,255,255,0.08); transform: translateX(4px); }
  .contact-link__label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-tertiary); margin-bottom: 4px; }
  .contact-link__value { font-family: var(--font-display); font-size: 18px; font-weight: 600; letter-spacing: -0.01em; color: var(--ivory); }
  .contact-link__arrow { font-size: 20px; color: var(--terracotta); transition: transform 0.2s ease; }
  .contact-link:hover .contact-link__arrow { transform: translateX(4px); }
  @media (max-width: 900px) {
    .contact { padding: var(--space-8) var(--space-5); }
    .contact__inner { grid-template-columns: 1fr; gap: var(--space-7); }
  }
</style>
