---
import type { Translations } from '../i18n/en';
interface Props { t: Translations; }
const { t } = Astro.props;
const a = t.about;
const sk = a.skillGroups;
---
<section class="about" id="about">
  <div class="about__intro">
    <p class="section-label reveal">{a.label}</p>
    <h2 class="about__heading reveal">{a.heading1}<br />{a.heading2}</h2>
    <p class="about__text reveal" set:html={a.body1} />
    <p class="about__text reveal" set:html={a.body2} />
    <div class="about__stats reveal">
      <div class="stat"><div class="stat__number">12<span>+</span></div><div class="stat__label">{a.stats.years}</div></div>
      <div class="stat"><div class="stat__number">9</div><div class="stat__label">{a.stats.companies}</div></div>
      <div class="stat"><div class="stat__number">3</div><div class="stat__label">{a.stats.leadership}</div></div>
      <div class="stat"><div class="stat__number">2M<span>+</span></div><div class="stat__label">{a.stats.users}</div></div>
    </div>
  </div>

  <div class="skills-grid">
    <div class="reveal">
      <p class="skills-group__title">{sk.frontend}</p>
      <div class="skills-group__tags">
        <span class="tag tag--accent">React.js</span><span class="tag tag--accent">Next.js</span>
        <span class="tag tag--accent">Vue.js</span><span class="tag tag--accent">React Native</span>
        <span class="tag">Angular</span><span class="tag">Redux</span>
        <span class="tag">Webpack</span><span class="tag">Styled Components</span><span class="tag">Three.js</span>
      </div>
    </div>
    <div class="reveal">
      <p class="skills-group__title">{sk.designSystems}</p>
      <div class="skills-group__tags">
        <span class="tag tag--accent">Design Systems</span><span class="tag tag--accent">Figma Code Connect</span>
        <span class="tag tag--accent">Figma to Code</span><span class="tag">Storybook</span>
        <span class="tag">Component Libraries</span><span class="tag">AI-assisted Dev</span>
      </div>
    </div>
    <div class="reveal">
      <p class="skills-group__title">{sk.backend}</p>
      <div class="skills-group__tags">
        <span class="tag tag--accent">Node.js</span><span class="tag tag--accent">GraphQL</span>
        <span class="tag">Express</span><span class="tag">Strapi</span>
        <span class="tag">RESTful APIs</span><span class="tag">Java</span><span class="tag">PHP</span>
      </div>
    </div>
    <div class="reveal">
      <p class="skills-group__title">{sk.cloud}</p>
      <div class="skills-group__tags">
        <span class="tag tag--accent">AWS</span><span class="tag">Firebase</span>
        <span class="tag">CI/CD</span><span class="tag">CircleCI</span>
        <span class="tag">Docker</span><span class="tag">CodePush</span><span class="tag">AppCenter</span>
      </div>
    </div>
    <div class="reveal">
      <p class="skills-group__title">{sk.data}</p>
      <div class="skills-group__tags">
        <span class="tag">MongoDB</span><span class="tag">PostgreSQL</span>
        <span class="tag">MySQL</span><span class="tag">Oracle / PLSQL</span>
      </div>
    </div>
    <div class="reveal">
      <p class="skills-group__title">{sk.realtime}</p>
      <div class="skills-group__tags">
        <span class="tag tag--accent">Web3</span><span class="tag tag--accent">WebRTC</span>
        <span class="tag">WebSockets</span><span class="tag">Socket.IO</span><span class="tag">DFNS</span>
      </div>
    </div>
  </div>
</section>
<div class="section-divider"></div>

<style>
  .about {
    background: var(--parchment); padding: var(--space-10) var(--space-8);
    display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-9);
    align-items: start; max-width: 1280px; margin: 0 auto;
  }
  .about__intro { position: sticky; top: calc(56px + var(--space-6)); }
  .about__heading {
    font-family: var(--font-display); font-size: clamp(32px,4vw,52px);
    font-weight: 700; letter-spacing: -0.02em; line-height: 1.1;
    color: var(--text-primary); margin-bottom: var(--space-5);
  }
  .about__text {
    font-family: var(--font-serif); font-size: 19px; font-weight: 400;
    line-height: 1.7; color: var(--text-secondary); margin-bottom: var(--space-4);
  }
  .about__text :global(strong) { color: var(--text-primary); font-weight: 600; }
  .about__stats { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); margin-top: var(--space-6); }
  .stat {
    padding: var(--space-4) var(--space-5); border-radius: 12px;
    background: var(--ivory); box-shadow: var(--shadow-card);
  }
  .stat__number {
    font-family: var(--font-display); font-size: 36px; font-weight: 800;
    letter-spacing: -0.03em; color: var(--text-primary); line-height: 1; margin-bottom: 4px;
  }
  .stat__number span { color: var(--terracotta); }
  .stat__label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-tertiary); }
  .skills-grid { display: flex; flex-direction: column; gap: var(--space-6); }
  .skills-group__title { font-family: var(--font-mono); font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-tertiary); margin-bottom: var(--space-3); }
  .skills-group__tags { display: flex; flex-wrap: wrap; gap: 8px; }
  @media (max-width: 900px) {
    .about { grid-template-columns: 1fr; padding: var(--space-8) var(--space-5); gap: var(--space-7); }
    .about__intro { position: static; }
  }
  @media (max-width: 600px) { .about__stats { grid-template-columns: 1fr; } }
</style>
