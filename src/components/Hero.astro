---
import type { Translations } from '../i18n/en';
interface Props { t: Translations; }
const { t } = Astro.props;
const h = t.hero;
---
<section class="hero" id="hero">
  <div class="hero__grid-bg" aria-hidden="true"></div>
  <div class="hero__glow" aria-hidden="true"></div>

  <div class="hero__content">
    <img src="/avatar.jpg" alt="Luis Tiburcio" class="hero__avatar" id="hero-avatar" />
    <p class="hero__tag" id="hero-tag">{h.tag}</p>
    <h1 class="hero__headline" id="hero-headline">
      {h.headline1}<br /><em>{h.headline2}</em><br />{h.headline3}
    </h1>
    <p class="hero__body" id="hero-body">{h.body}</p>
    <div class="hero__meta" id="hero-meta">
      <span class="hero__meta-item"><span class="hero__meta-dot"></span>{h.meta1}</span>
      <span class="hero__meta-item"><span class="hero__meta-dot"></span>{h.meta2}</span>
      <span class="hero__meta-item"><span class="hero__meta-dot"></span>{h.meta3}</span>
    </div>
  </div>

  <div class="hero__scroll">{h.scroll}</div>
</section>

<style>
  .hero {
    min-height: 100vh;
    background: var(--bg-base);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: calc(60px + var(--space-10)) var(--space-8) var(--space-11);
    position: relative;
    overflow: hidden;
  }

  /* Grid background */
  .hero__grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border-subtle) 1px, transparent 1px),
      linear-gradient(90deg, var(--border-subtle) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
    z-index: 0;
  }

  /* Violet radial glow */
  .hero__glow {
    position: absolute;
    bottom: -10%; left: -5%;
    width: 65%; height: 75%;
    background: radial-gradient(ellipse at 0% 100%, rgba(124,58,237,0.14) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* Content wrapper — scroll-driven parallax fade-out */
  .hero__content {
    position: relative;
    z-index: 1;
    animation: heroParallax linear both;
    animation-timeline: scroll(root block);
    animation-range: 0vh 60vh;
  }
  @keyframes heroParallax {
    0%   { opacity: 1; translate: 0 0;     filter: blur(0px); }
    70%  { opacity: 0.4; translate: 0 -40px; filter: blur(0px); }
    100% { opacity: 0;   translate: 0 -80px; filter: blur(4px); }
  }
  @supports not (animation-timeline: scroll()) {
    .hero__content { animation: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__content { animation: none; }
  }

  /* Avatar */
  .hero__avatar {
    width: 72px; height: 72px;
    border-radius: 50%;
    object-fit: cover;
    box-shadow:
      0 0 0 2px var(--accent),
      0 0 0 4px rgba(124,58,237,0.2),
      0 0 24px rgba(124,58,237,0.3);
    margin-bottom: var(--space-5);
    opacity: 0;
    transform: scale(0.9);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .hero__avatar.visible { opacity: 1; transform: scale(1); }

  /* Tag */
  .hero__tag {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-bright);
    margin-bottom: var(--space-5);
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .hero__tag.visible { opacity: 1; transform: translateY(0); }

  /* Headline */
  .hero__headline {
    font-family: var(--font-sans);
    font-size: clamp(52px, 8.5vw, 116px);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    max-width: 14ch;
    margin-bottom: var(--space-6);
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease 0.1s, transform 0.8s ease 0.1s;
  }
  .hero__headline.visible { opacity: 1; transform: translateY(0); }
  .hero__headline em {
    font-style: normal;
    background: linear-gradient(135deg, var(--accent-bright) 0%, #c4b5fd 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Body */
  .hero__body {
    font-family: var(--font-sans);
    font-size: clamp(17px, 2vw, 20px);
    font-weight: 400;
    line-height: 1.65;
    color: var(--text-secondary);
    max-width: 52ch;
    margin-bottom: var(--space-7);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.8s ease 0.2s, transform 0.8s ease 0.2s;
  }
  .hero__body.visible { opacity: 1; transform: translateY(0); }

  /* Meta */
  .hero__meta {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s ease 0.35s, transform 0.6s ease 0.35s;
  }
  .hero__meta.visible { opacity: 1; transform: translateY(0); }
  .hero__meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    text-transform: uppercase;
  }
  .hero__meta-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    box-shadow: 0 0 6px rgba(124,58,237,0.7);
  }

  /* Scroll indicator */
  .hero__scroll {
    position: absolute;
    bottom: var(--space-7);
    right: var(--space-8);
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    z-index: 1;
    animation: scrollPulse 2.5s ease-in-out infinite;
  }
  @keyframes scrollPulse { 0%,100% { opacity: 0.3 } 50% { opacity: 0.7 } }

  @media (max-width: 900px) {
    .hero { padding: calc(60px + var(--space-8)) var(--space-5) var(--space-8); }
  }
  @media (max-width: 480px) {
    .hero__headline { font-size: clamp(40px, 12vw, 56px); }
  }
</style>
