---
import type { Translations } from '../i18n/en';
import type { Lang } from '../i18n/utils';
import { getLocalePath } from '../i18n/utils';

interface Props { t: Translations; lang: Lang; }
const { t, lang } = Astro.props;
const otherLang = lang === 'en' ? 'es' : 'en';
---
<nav class="nav" id="nav">
  <span class="nav__logo">Luis Tiburcio</span>
  <div class="nav__links">
    <a href={`${getLocalePath(lang)}#about`}>{t.nav.about}</a>
    <a href={`${getLocalePath(lang)}#experience`}>{t.nav.experience}</a>
    <a href={`${getLocalePath(lang)}#contact`}>{t.nav.contact}</a>
    <a href={getLocalePath(otherLang)} class="nav__lang">{t.nav.langSwitch}</a>
    <a href="mailto:luist.webdesigner@gmail.com" class="nav__cta">{t.nav.hire}</a>
  </div>
</nav>

<style>
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    height: 60px;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 var(--space-8);
    background: transparent;
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    border-bottom: 1px solid transparent;
    animation: navFill linear both;
    animation-timeline: scroll(root block);
    animation-range: 0px 80vh;
  }
  @keyframes navFill {
    from {
      background: transparent;
      backdrop-filter: blur(0px);
      -webkit-backdrop-filter: blur(0px);
      border-bottom-color: transparent;
    }
    to {
      background: rgba(10,10,15,0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom-color: var(--border-subtle);
    }
  }
  @supports not (animation-timeline: scroll()) {
    .nav {
      background: rgba(10,10,15,0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border-subtle);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .nav {
      animation: none;
      background: rgba(10,10,15,0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border-subtle);
    }
  }

  .nav__logo {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--text-primary);
    text-transform: uppercase;
  }

  .nav__links { display: flex; align-items: center; gap: var(--space-6); }

  .nav__links a {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    text-transform: uppercase;
    transition: color var(--ease-color);
  }
  .nav__links a:hover { color: var(--accent-bright); }

  .nav__lang {
    border-radius: 6px;
    box-shadow: 0 0 0 1px var(--border-subtle);
    padding: 5px 10px !important;
    background: rgba(255,255,255,0.04);
    color: var(--text-secondary) !important;
    transition: background var(--ease-color), box-shadow var(--ease-shadow) !important;
  }
  .nav__lang:hover {
    background: rgba(255,255,255,0.08) !important;
    box-shadow: 0 0 0 1px var(--border-default) !important;
    color: var(--text-primary) !important;
  }

  .nav__cta {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 8px 18px;
    border-radius: 8px;
    background: var(--accent);
    color: var(--text-primary) !important;
    box-shadow: 0 0 0 1px var(--accent-border), var(--shadow-glow);
    transition: background var(--ease-color), box-shadow var(--ease-shadow);
  }
  .nav__cta:hover {
    background: var(--accent-bright);
    box-shadow: 0 0 0 1px rgba(139,92,246,0.5), 0 0 32px rgba(124,58,237,0.5), 0 0 64px rgba(124,58,237,0.2);
  }

  @media (max-width: 900px) {
    .nav { padding: 0 var(--space-5); }
    .nav__links a:not(.nav__cta):not(.nav__lang) { display: none; }
  }
</style>
